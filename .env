# ── App ───────────────────────────────────────────────────────────────────────
APP_NAME=Thermal Printer Service
APP_VERSION=1.0.0
DEBUG=false
PORT=3000

# ── Connection mode: simulation | usb | ethernet ──────────────────────────────
CONNECTION_MODE=simulation

# USB (only used if CONNECTION_MODE=usb)
PRINTER_USB_VENDOR_ID=0x0519
PRINTER_USB_PRODUCT_ID=0x0001

# Ethernet (only used if CONNECTION_MODE=ethernet)
PRINTER_ETH_HOST=192.168.1.100
PRINTER_ETH_PORT=9100

# ── Queue & retry ─────────────────────────────────────────────────────────────
MAX_RETRY_ATTEMPTS=3
RETRY_BACKOFF_BASE=2.0
JOB_TIMEOUT_SECONDS=30

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=sqlite:///./thermal_printer.db

# ── Paper prediction ──────────────────────────────────────────────────────────
PAPER_ROLL_INITIAL_METERS=50.0
AVG_PAPER_PER_PRINT_CM=10.0

# ── Optional API token (leave empty to disable auth) ─────────────────────────
API_TOKEN=
